import sys

def checkSlope(L, rightSteps, downSteps):
    """For part 2"""
    output = []; output.append(L[0])
    wrap = len(L[0])
    idx = 0
    nTrees = 0
    for line in L[downSteps::downSteps]:
        idx = (idx + rightSteps) % wrap
        if line[idx] == "#":
            nTrees += 1
            c = "X"
        else:
            c = "O"
        output.append(line[0:idx] + c + line[idx + 1:])
    print("\n\n")
    for s in output:
        print(s)
    return nTrees

